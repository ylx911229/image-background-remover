{
  "name": "image-background-remover",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run build && wrangler d1 migrations apply image-background-remover-auth --local && wrangler pages dev out --port 8789",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler pages deploy out --project-name=image-background-remover --commit-dirty=true"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "^5.7.0",
    "wrangler": "^4.107.0"
  }
}
